# ==============================================
# Infinite Helix – Environment Variables
# Copy this file to .env and fill in your values
# ==============================================

# Flask
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key

# Demo Mode (set to false for production with real Firebase/models)
DEMO_MODE=true
DESKTOP_NOTIFICATIONS=true

# Firebase
FIREBASE_CREDENTIALS_PATH=./config/firebase-credentials.json

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/callback

# Microsoft Teams / Outlook Calendar (Azure AD App Registration)
# 1. Go to https://portal.azure.com → Azure Active Directory → App registrations
# 2. Create new registration, set redirect URI to the callback URL below
# 3. Under API permissions, add Microsoft Graph → Calendars.Read, User.Read
# 4. Under Certificates & Secrets, create a client secret
MS_CLIENT_ID=your-microsoft-client-id
MS_CLIENT_SECRET=your-microsoft-client-secret
MS_TENANT_ID=your-tenant-id
MS_REDIRECT_URI=http://localhost:5000/api/calendar/callback

# AI Models
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment
MODEL_CACHE_DIR=./model_cache

# Tracker
TRACKER_INTERVAL_SECONDS=30
NUDGE_COOLDOWN_MINUTES=30
IDLE_THRESHOLD_SECONDS=60
FATIGUE_THRESHOLD_MINUTES=120
